*.md
docs/
LICENSE

# IDE & Editor configs
.vscode
.idea
*.swp
*.swo
*~

# Testing
coverage/
__mocks__/
jest.config.js
jest.setup.ts
test-output*.txt
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Agent/AI configs (development only)
.agent/
.agents/
.gemini/

# OS files
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
