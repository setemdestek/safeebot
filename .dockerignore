# Dependencies (will be installed fresh in Docker)
node_modules

# Build output (will be built in Docker)
.next
out
build

# Version control
.git
.gitignore

# Docker files (prevent recursive copy)
Dockerfile
docker-compose.yml
.dockerignore

# Environment files (injected via Coolify, not copied)
.env*
!.env.example

